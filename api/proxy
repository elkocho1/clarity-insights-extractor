export const config = {
  runtime: 'edge',
};

export default async function handler(req) {
  const corsHeaders = {
    'Access-Control-Allow-Origin': '*',
    'Access-Control-Allow-Methods': 'POST, OPTIONS',
    'Access-Control-Allow-Headers': 'Content-Type, x-api-key',
    'Content-Type': 'application/json',
  };

  if (req.method === 'OPTIONS') {
    return new Response(null, { status: 200, headers: corsHeaders });
  }

  if (req.method !== 'POST') {
    return new Response(JSON.stringify({ error: 'Method not allowed' }), { status: 405, headers: corsHeaders });
  }

  const apiKey = req.headers.get('x-api-key');
  if (!apiKey) {
    return new Response(JSON.stringify({ error: 'Missing API key' }), { status: 400, headers: corsHeaders });
  }

  let body = {};
  try {
    body = await req.json();
  } catch(e) {
    return new Response(JSON.stringify({ error: 'Invalid JSON body' }), { status: 400, headers: corsHeaders });
  }

  // Test mode
  if (body.test) {
    try {
      const r = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': apiKey,
          'anthropic-version': '2023-06-01',
        },
        body: JSON.stringify({
          model: 'claude-haiku-4-5-20251001',
          max_tokens: 10,
          messages: [{ role: 'user', content: 'Hi' }]
        })
      });
      const d = await r.json();
      if (d.error) return new Response(JSON.stringify({ ok: false, error: d.error.message }), { status: 200, headers: corsHeaders });
      return new Response(JSON.stringify({ ok: true }), { status: 200, headers: corsHeaders });
    } catch(e) {
      return new Response(JSON.stringify({ ok: false, error: e.message }), { status: 200, headers: corsHeaders });
    }
  }

  // Extraction mode
  const { url } = body;
  if (!url) return new Response(JSON.stringify({ error: 'Missing url' }), { status: 400, headers: corsHeaders });

  try {
    // Step 1: Fetch Clarity page server-side
    const pageRes = await fetch(url, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
        'Accept': 'text/html,application/xhtml+xml',
        'Accept-Language': 'de-DE,de;q=0.9',
      }
    });
    const html = await pageRes.text();

    // Step 2: Regex extraction (free, no AI)
    const patterns = [
      /Der Nutzer[^<]{20,800}/,
      /Die Nutzerin[^<]{20,800}/,
      /Der Besucher[^<]{20,800}/,
      /Die Besucherin[^<]{20,800}/,
    ];

    let insight = null;
    for (const pattern of patterns) {
      const match = html.match(pattern);
      if (match) {
        insight = match[0]
          .replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>')
          .replace(/&quot;/g, '"').replace(/&#39;/g, "'").replace(/\s+/g, ' ')
          .trim().substring(0, 700);
        break;
      }
    }

    // Step 3: Claude Haiku fallback
    if (!insight) {
      const bodyStart = html.indexOf('<body');
      const relevantHtml = bodyStart > -1 ? html.substring(bodyStart, bodyStart + 5000) : html.substring(0, 5000);
      const claudeRes = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': apiKey,
          'anthropic-version': '2023-06-01',
        },
        body: JSON.stringify({
          model: 'claude-haiku-4-5-20251001',
          max_tokens: 400,
          system: 'Extract ONLY the Sitzungserkenntnisse paragraph from this HTML — a German summary starting with "Der Nutzer", "Die Nutzerin", "Der Besucher" or similar. Return ONLY that text. If not found return: NOT_FOUND',
          messages: [{ role: 'user', content: relevantHtml }]
        })
      });
      const claudeData = await claudeRes.json();
      if (claudeData.error) return new Response(JSON.stringify({ error: claudeData.error.message }), { status: 200, headers: corsHeaders });
      const text = claudeData.content?.filter(b => b.type === 'text').map(b => b.text).join('').trim();
      if (text && text !== 'NOT_FOUND') insight = text;
    }

    return new Response(JSON.stringify({ insight: insight || null }), { status: 200, headers: corsHeaders });

  } catch (err) {
    return new Response(JSON.stringify({ error: err.message }), { status: 200, headers: corsHeaders });
  }
}
